Acquire::http::Proxy "http://<%= @cacher_server['host'] %>:<%= @cacher_server['port'] %>";
<% if @cacher_server['proxy_ssl'] %>
Acquire::https::Proxy "http://<%= @cacher_server['host'] %>:<%= @cacher_server['port'] %>";
<% else %>
Acquire::https::Proxy "DIRECT";
<% end %>
<% unless @cacher_server['cache_bypass'].nil? %>
<% @cacher_server['cache_bypass'].each do |bypass, type| %>
Acquire::<%= type %>::Proxy::<%= bypass %> "DIRECT";
<% end %>
<% end %>
